GEMINI_API_KEY=your_api_key_here

# ── Model settings ────────────────────────────────────────────────────────────
# Temperature: 0.0 (deterministic) → 2.0 (max creativity)
GEMINI_TEMPERATURE=1.0

# Media resolution: LOW | MEDIUM | HIGH
GEMINI_MEDIA_RESOLUTION=MEDIUM

# Thinking level (pro & flash only): OFF | LOW | MEDIUM | HIGH
# Maps to thinking_budget: OFF=0, LOW=1024, MEDIUM=4096, HIGH=8192
GEMINI_THINKING_LEVEL=HIGH

# Max output tokens (1 → 65536)
GEMINI_MAX_OUTPUT_TOKENS=65536

# Top-p sampling (0.0 → 1.0)
GEMINI_TOP_P=0.95

# ── Tools ─────────────────────────────────────────────────────────────────────
# Enable/disable each tool: true | false
GEMINI_TOOL_CODE_EXECUTION=false
GEMINI_TOOL_GROUNDING_GOOGLE_SEARCH=false
GEMINI_TOOL_GROUNDING_GOOGLE_MAPS=false
GEMINI_TOOL_URL_CONTEXT=false
